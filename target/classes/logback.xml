<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Set Cling/UPnP related logs to INFO/WARN to reduce noise, but still show discovery events -->
    <logger name="org.fourthline.cling" level="INFO"/>
    
    <!-- App logs set to DEBUG for verbose detail on browsing and streaming -->
    <logger name="com.vypeensoft.dlnaserver" level="DEBUG"/>
</configuration>
